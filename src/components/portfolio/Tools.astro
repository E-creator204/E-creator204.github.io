---
const tools = [
  { name: "Kali Linux", icon: "🐉" },
  { name: "Nessus", icon: "🔍" },
  { name: "Wazuh", icon: "🛡️" },
  { name: "Zabbix", icon: "📊" },
  { name: "Grafana", icon: "📈" },
  { name: "pfSense", icon: "🔥" },
  { name: "WAF Safeline", icon: "🧱" },
  { name: "Docker", icon: "🐳" },
];
---

<div style="display:flex; flex-direction:column; gap:12px; width:100%;">
  {tools.map((tool) => (
    <div style="display:flex; flex-direction:column; gap:4px;">
      <div style="display:flex; align-items:center; justify-content:space-between;">
        <span style="display:flex; align-items:center; gap:8px; font-size:0.875rem; font-weight:600; color:white;">
          <span>{tool.icon}</span>
          {tool.name}
        </span>
        <span style="font-size:0.75rem; color:#4ade80; font-weight:700;">En uso</span>
      </div>
      <div style="width:100%; height:8px; border-radius:9999px; background:rgba(100,100,100,0.3); overflow:hidden;">
        <div style="height:100%; width:75%; border-radius:9999px; background: linear-gradient(to right, #6ee7b7, #34d399);" />
      </div>
    </div>
  ))}
</div>