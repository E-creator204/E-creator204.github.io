---
import { Icon } from "astro-icon/components";

const tools = [
  { name: "Kali Linux", icon: "simple-icons:kalilinux" },
  //{ name: "Nessus", icon: "simple-icons:nessus" },
  //{ name: "Wazuh", icon: "simple-icons:wazuh" },
  { name: "Zabbix", icon: "logos:zabbix" },
  { name: "Grafana", icon: "grafana" },
  { name: "pfSense", icon: "simple-icons:pfsense" },
  { name: "WAF Safeline", icon: "owasp" },
  { name: "Docker", icon: "simple-icons:docker" },
];
---

<div class="flex flex-col gap-3 w-full">
  {tools.map((tool) => (
    <div class="flex flex-col gap-3 rounded-3xl border border-white/10 bg-white/5 p-4 shadow-sm shadow-black/10 dark:border-zinc-800 dark:bg-zinc-900/70">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-mint-950/10 text-mint-400 ring-1 ring-mint-300/20 dark:bg-mint-500/10 dark:text-mint-200">
            <Icon name={tool.icon} class="size-5" aria-hidden="true" />
          </span>
          <span class="text-sm font-semibold text-white">{tool.name}</span>
        </div>
        <span class="rounded-full bg-emerald-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-300">
          En uso
        </span>
      </div>
      <div class="h-2 w-full overflow-hidden rounded-full bg-white/10">
        <div class="h-full w-3/4 rounded-full bg-gradient-to-r from-mint-400 to-riptide-400" />
      </div>
    </div>
  ))}
</div>